{
  "name": "FateX RU",
  "system": "fatex",
  "author": "YoshiakiHisaka",
  "version": "1.1.0",
  "minimumSystemVersion": "1.5.4",
  "offline_excludes": [
    "npc"
  ],
  "rows": [
    [
      {
        "name": "Портрет",
        "type": "direct",
        "header": "show",
        "text": "{charactersheet}",
        "align": "center"
      },
      {
        "name": "Аспекты",
        "type": "object-loop",
        "header": "show",
        "text": "items{type == 'aspect' && system.label != ''} => {b}{system.label}{/b}: {system.value}{nl}",
        "align": "left",
        "rowspan": 3,
        "valign": "top"
      },
      {
        "name": "Последствия",
        "type": "object-loop",
        "header": "show",
        "text": "items{type == 'consequence' && system.value != '' && system.label != ''} => {b}{system.label}{/b}: {system.value}{nl}",
        "align": "left",
        "rowspan": 3,
        "valign": "top"
      }
    ],
    [
      {
        "name": "Имя",
        "type": "direct",
        "header": "show",
        "text": "{name}",
        "align": "center"
      },
      {
        "name": "",
        "type": "span",
        "header": "show",
        "text": "",
        "colspan": 2
      }
    ],
    [
      {
        "name": "Жетоны",
        "type": "direct",
        "header": "show",
        "text": "{system.fatepoints.current} / {system.fatepoints.refresh}",
        "align": "center"
      },
      {
        "name": "",
        "type": "span",
        "header": "show",
        "text": "",
        "colspan": 2
      }
    ]
  ]
}